<?xml version="1.0" encoding="utf-8"?>
<MsixPackagingToolTemplate
    xmlns="http://schemas.microsoft.com/msix/packaging/msixpackagingtool/template/2022">
    <Settings
        AllowTelemetry="false"
        ApplyACLsToPackageFiles="true"
        GenerateCommandLineFile="true"
        AllowPromptForPassword="false">
    </Settings>
    <Installer
        Path="cashier"
        Arguments=""
        InstallLocation="C:\Program Files\Zawan\Cashier POS">
    </Installer>
    <PackageInformation
        PackageName="Cashier POS"
        PackageDisplayName="Cashier POS"
        PublisherName="CN=Zawan"
        PublisherDisplayName="Zawan"
        Version="1.0.0.0"
        PackageDescription="نقطة البيع - كاشير">
        <Capabilities>
            <Capability Name="runFullTrust" />
            
        </Capabilities>
        <Applications>
            <Application
                Id="com.zawan.cashier"
                Description="نقطة البيع - كاشير"
                DisplayName="Cashier POS"
                ExecutableName="cashier"
                EntryPoint="Windows.FullTrustApplication">
                
            </Application>
        </Applications>
        <Resources>
            <Resource Language="en-us" />
        </Resources>
        <Dependencies>
            <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.17763.0" MaxVersionTested="10.0.19041.0" />
        </Dependencies>
        <Properties>
            <Framework>false</Framework>
            <DisplayName>Cashier POS</DisplayName>
            <PublisherDisplayName>Zawan</PublisherDisplayName>
            <Description>نقطة البيع - كاشير</Description>
            <Logo>Assets\AppIcon.png</Logo>
        </Properties>
    </PackageInformation>
    <SaveLocation PackagePath="cashier.msix" />
    <PackageIntegrity>
        <CertificatePath></CertificatePath>
    </PackageIntegrity>
</MsixPackagingToolTemplate>
